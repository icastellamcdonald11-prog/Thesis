# Copy to .env and fill in locally. Never commit the real .env file.
# In GitHub Actions these are set as repository secrets instead (see .github/workflows/daily.yml).

# Required for Stage 2 (Haiku triage) and Stage 3 (Sonnet differentiation check).
ANTHROPIC_API_KEY=

# Required for digest email sending (Stage 4). Leave EMAIL_ENABLED=false to skip email
# and only write digests/YYYY-MM-DD.md.
EMAIL_ENABLED=true
SMTP_USERNAME=
SMTP_PASSWORD=
# Comma-separated list of recipient addresses.
EMAIL_TO=
